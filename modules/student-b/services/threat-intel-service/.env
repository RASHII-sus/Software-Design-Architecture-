NODE_ENV=development
PORT=3002

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=sdapro
POSTGRES_PASSWORD=sdapro_secret
POSTGRES_DB=sdapro

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret

# RabbitMQ
RABBITMQ_URL=amqp://sdapro:rabbitmq_secret@localhost:5672/sdapro

# VirusTotal
VIRUSTOTAL_API_KEY=your_virustotal_api_key
VIRUSTOTAL_BASE_URL=https://www.virustotal.com/api/v3
VIRUSTOTAL_RATE_LIMIT_PER_MINUTE=4

# MISP
MISP_BASE_URL=https://your-misp-instance.com
MISP_AUTH_KEY=your_misp_auth_key
MISP_RATE_LIMIT_PER_MINUTE=60

# Custom Feed
CUSTOM_FEED_URL=https://your-custom-feed.com/api
CUSTOM_FEED_API_KEY=your_custom_feed_key
CUSTOM_FEED_RATE_LIMIT_PER_MINUTE=30

# Cache
THREAT_INTEL_CACHE_TTL_SECONDS=3600

# Internal API Key
API_KEY_SECRET=internal_api_key_secret
