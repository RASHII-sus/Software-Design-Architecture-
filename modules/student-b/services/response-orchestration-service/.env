NODE_ENV=development
PORT=3003

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=sdapro
POSTGRES_PASSWORD=sdapro_secret
POSTGRES_DB=sdapro

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret

RABBITMQ_URL=amqp://sdapro:rabbitmq_secret@localhost:5672/sdapro

THREAT_INTEL_SERVICE_URL=http://localhost:3002
API_KEY_SECRET=internal_api_key_secret

# Approval gate — set to false to auto-approve all actions in dev
REQUIRE_APPROVAL_FOR_CRITICAL=true
AUTO_ROLLBACK_ON_FAILURE=true
