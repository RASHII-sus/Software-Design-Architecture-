NODE_ENV=development
PORT=3004

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=sdapro
POSTGRES_PASSWORD=sdapro_secret
POSTGRES_DB=sdapro

RABBITMQ_URL=amqp://sdapro:rabbitmq_secret@localhost:5672/sdapro

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=alerts@example.com
SMTP_PASS=smtp_password
SMTP_FROM=SDA-Pro Alerts <alerts@example.com>

# Slack
SLACK_BOT_TOKEN=xoxb-your-token
SLACK_DEFAULT_CHANNEL=#soc-alerts

# PagerDuty
PAGERDUTY_API_KEY=your_api_key
PAGERDUTY_SERVICE_KEY=your_service_key

# Tier: ENTERPRISE enables all three channels; BASIC enables only email
NOTIFICATION_TIER=ENTERPRISE
