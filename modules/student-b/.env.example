# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=sdapro
POSTGRES_PASSWORD=sdapro_secret
POSTGRES_DB=sdapro
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret

# ─── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_USER=sdapro
RABBITMQ_PASSWORD=rabbitmq_secret
RABBITMQ_VHOST=sdapro
RABBITMQ_URL=amqp://sdapro:rabbitmq_secret@localhost:5672/sdapro

# ─── External API Keys ────────────────────────────────────────────────────────
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here
VIRUSTOTAL_BASE_URL=https://www.virustotal.com/api/v3
MISP_BASE_URL=https://your-misp-instance.com
MISP_AUTH_KEY=your_misp_auth_key_here
CUSTOM_FEED_URL=https://your-custom-feed.com/api
CUSTOM_FEED_API_KEY=your_custom_feed_key_here

# ─── Notification Channels ────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=alerts@example.com
SMTP_PASS=smtp_password
SMTP_FROM=SDA-Pro Alerts <alerts@example.com>
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_DEFAULT_CHANNEL=#soc-alerts
PAGERDUTY_API_KEY=your_pagerduty_api_key
PAGERDUTY_SERVICE_KEY=your_pagerduty_service_key

# ─── Service URLs ─────────────────────────────────────────────────────────────
THREAT_INTEL_SERVICE_URL=http://localhost:3002
RESPONSE_ORCHESTRATION_SERVICE_URL=http://localhost:3003
NOTIFICATION_SERVICE_URL=http://localhost:3004
MIDDLEWARE_URL=http://localhost:3005

# ─── Rate Limiting ────────────────────────────────────────────────────────────
VIRUSTOTAL_RATE_LIMIT_PER_MINUTE=4
MISP_RATE_LIMIT_PER_MINUTE=60
THREAT_INTEL_CACHE_TTL_SECONDS=3600

# ─── Security ─────────────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_here
API_KEY_SECRET=your_internal_api_key_here
